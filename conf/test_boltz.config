/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full size pipeline test.

    Use as follows:
        nextflow run nf-core/proteinfold -profile test_full_esmfold,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

stubRun = true

process {
    resourceLimits = [
        cpus: 1,
        memory: '2.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'stub test profile for boltz'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data for full test of boltz
    mode                    = 'boltz'
    colabfold_model_preset  = 'alphafold2_multimer_v3'  //this should be redundant
    input                   = params.pipelines_testdata_base_path + 'proteinfold/testdata/samplesheet/v2.0/samplesheet.csv'
    colabfold_db            = "${projectDir}/assets/dummy_db_dir"
    boltz_db                = "${projectDir}/assets/dummy_db_dir"
}

process {
    withName: 'MMSEQS_COLABFOLDSEARCH|RUN_BOLTZ' {
        container = 'biocontainers/gawk:5.1.0'
    }
}
