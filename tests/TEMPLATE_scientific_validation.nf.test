/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Scientific Validation Test Template for Structure Prediction Modes
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    Focus: Ensure outputs are *consistent and well-formed*, not quality assessment.

    This template is designed for modes without seed parameters (boltz, esmfold,
    colabfold, rosettafold_all_atom, rosettafold2na, helixfold3, alphafold3).

    Replace TEMPLATE_MODE with your actual mode name (boltz, esmfold, etc.)

    For modes with seed parameters (like alphafold2), use alphafold2_scientific_validation.nf.test
    as a reference and extend with seed-specific tests.
*/

nextflow_pipeline {

    name "Scientific validation: TEMPLATE_MODE output consistency"
    script "../main.nf"
    tag "scientific"
    tag "TEMPLATE_MODE"
    tag "output_validation"

    // CORE TEST: Output files exist and are well-formed
    test("TEMPLATE_MODE: Core output validation") {
        options "-profile test_TEMPLATE_MODE"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success: "Workflow failed"

            // CORE VALIDATIONS using base helpers
            // These assertions verify the pipeline produces expected outputs

            // 1. Check metrics files (pLDDT, MSA) exist and have content
            assert validateModeMetrics(params.outdir, 'TEMPLATE_MODE'): \
                "TEMPLATE_MODE failed to produce metrics files"

            // 2. Check structure files (PDB/CIF) are well-formed
            def struct_count = validateModeStructures(params.outdir, '.pdb')
            assert struct_count > 0: "No structure files generated"

            // 3. Get metrics for snapshot (counts should be reproducible)
            def metrics = getMetricsOutput(params.outdir)

            // OPTIONAL: Validate optional PAE outputs (if multimer)
            // Uncomment if your mode produces PAE files:
            // def pae = validatePAEOutput(params.outdir)

            // Snapshot: File counts, names, and metrics
            // This ensures outputs are consistent across workflow runs
            snapshot(
                workflow.trace.succeeded().size(),
                metrics.plddt_count,
                metrics.msa_count,
                struct_count,
                metrics.plddt_names.sort(),
                metrics.msa_names.sort(),
                removeNextflowVersion("$outputDir/pipeline_info/nf_core_proteinfold_software_mqc_versions.yml")
            ).match()
        }
    }

    // OPTIONAL: Test with multiple proteins
    test("TEMPLATE_MODE: Multiple proteins consistency") {
        options "-profile test_TEMPLATE_MODE"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // Verify all input proteins are processed
            def pdb_files = file("${params.outdir}/**/*.pdb", relative: true)
            def plddt_files = file("${params.outdir}/**/*plddt.tsv", relative: true)

            // Should have at least 2 proteins in test samplesheet
            assert pdb_files.size() >= 2: \
                "Expected at least 2 PDB files, got ${pdb_files.size()}"
            assert plddt_files.size() >= 2: \
                "Expected at least 2 pLDDT files, got ${plddt_files.size()}"

            // All proteins should have both PDB and pLDDT
            snapshot(
                pdb_files.collect { it.name }.sort(),
                plddt_files.collect { it.name }.sort()
            ).match()
        }
    }

    // OPTIONAL: Mode-specific output structure test
    test("TEMPLATE_MODE: Output directory structure") {
        options "-profile test_TEMPLATE_MODE"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // Validate mode-specific directory layout
            // Example: ${outdir}/TEMPLATE_MODE/{protein_id}/**
            def mode_structure = getModeOutputStructure(
                params.outdir,
                'TEMPLATE_MODE'
                // Add variant if applicable (e.g., for alphafold2 with split_msa_prediction):
                // 'split_msa_prediction'
            )

            assert mode_structure.exists: \
                "TEMPLATE_MODE output directory not found"
            assert mode_structure.protein_count > 0: \
                "No proteins processed"

            snapshot(
                mode_structure.protein_count,
                mode_structure.proteins.sort()
            ).match()
        }
    }

    // ADVANCED (Optional): Add mode-specific tests
    // Example test structure for reproducibility or quality checks:
    /*
    test("TEMPLATE_MODE: Reproducibility across runs") {
        options "-profile test_TEMPLATE_MODE"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // For stochastic methods: verify outputs are structurally valid
            // even if exact values vary
            assert validateModeStructures(params.outdir, '.pdb') > 0

            // Snapshot only counts, not content
            // (since runs produce different results)
            snapshot(
                workflow.trace.succeeded().size()
            ).match()
        }
    }
    */
}
