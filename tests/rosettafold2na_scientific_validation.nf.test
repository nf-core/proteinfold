/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Scientific Validation: RoseTTAFold2NA Output Consistency
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    Tests for RNA/DNA + protein structure prediction validation.
    Focus: Ensure outputs are consistent and well-formed.
*/

nextflow_pipeline {

    name "Scientific validation: RoseTTAFold2NA output consistency"
    script "../main.nf"
    tag "scientific"
    tag "rosettafold2na"
    tag "output_validation"

    test("RoseTTAFold2NA: Core output validation") {
        options "-profile test_rosettafold2na"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success: "RoseTTAFold2NA workflow failed"

            assert validateModeMetrics(params.outdir, 'rosettafold2na'): \
                "RoseTTAFold2NA failed to produce metrics"

            def struct_count = validateModeStructures(params.outdir, '.pdb')
            assert struct_count > 0: "No PDB structures generated"

            def metrics = getMetricsOutput(params.outdir)

            snapshot(
                workflow.trace.succeeded().size(),
                metrics.plddt_count,
                metrics.msa_count,
                struct_count,
                removeNextflowVersion("$outputDir/pipeline_info/nf_core_proteinfold_software_mqc_versions.yml")
            ).match()
        }
    }
}
