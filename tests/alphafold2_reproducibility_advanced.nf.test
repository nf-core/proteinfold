/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    CI/CD Reproducibility Tests for AlphaFold2
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Regression tests to ensure consistency as workflow code changes.
    
    Tests for:
    - Fixed random seed reproducibility (same input + same seed → consistent output)
    - Output file generation and structure
    - Deterministic predictions with fixed seed
    
    No quality assertions. Focus: workflow consistency, not prediction quality.
*/

nextflow_pipeline {

    name "Advanced scientific validation: Reproducibility and structure comparison"
    script "../main.nf"
    tag "scientific_advanced"
    tag "reproducibility"

    test("Structure quality metrics from B-factors") {
        options "-profile test_alphafold_fixed_seed"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // PRIMARY: Validate pLDDT TSV output files (extract_metrics.py product)
            def plddt_files = file("${params.outdir}/**/alphafold2/*/*/*plddt.tsv", relative: true)
            assert plddt_files.size() > 0: "No pLDDT TSV files found"

            // Each TSV should have readable content
            plddt_files.each { plddt_file ->
                def content = plddt_file.text
                assert !content.isEmpty(): "Empty pLDDT TSV: ${plddt_file.name}"
            }

            // SECONDARY: Verify underlying PDB structures provide the B-factors to extract_metrics
            def pdb_files = file("${params.outdir}/alphafold2/split_msa_prediction/*/*.pdb", relative: true)
            assert pdb_files.size() > 0: "No PDB files found (input to extract_metrics.py)"

            pdb_files.each { pdb_file ->
                def content = pdb_file.text
                assert !content.isEmpty(): "Empty PDB file: ${pdb_file.name}"
                assert content.contains("ATOM"): "No ATOM records in ${pdb_file.name}"
            }

            snapshot(
                plddt_files.size(),
                pdb_files.size(),
                workflow.trace.succeeded().size()
            ).match()
        }
    }

    test("pLDDT score distribution validation") {
        options "-profile test_alphafold_random_seed_fuzzy"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // PRIMARY: Collect and validate pLDDT TSV files from extract_metrics.py
            def plddt_files = file("${params.outdir}/**/alphafold2/*/*/*plddt.tsv", relative: true)
            assert plddt_files.size() > 0: "No pLDDT TSV files found"

            // Validate each TSV file is readable
            // Detailed parsing with csv module happens in Python (not here)
            def protein_scores = [:]
            def total_files = 0

            plddt_files.each { plddt_file ->
                def content = plddt_file.text
                assert !content.isEmpty(): "Empty pLDDT TSV: ${plddt_file}"
                
                // Extract protein ID from path for tracking
                def path_parts = plddt_file.toString().split("/")
                if (path_parts.size() > 0) {
                    def protein_id = path_parts[-2]
                    if (!protein_scores.containsKey(protein_id)) {
                        protein_scores[protein_id] = []
                    }
                    protein_scores[protein_id].add(plddt_file.toString())
                    total_files++
                }
            }

            assert protein_scores.size() > 0: "No proteins found in pLDDT TSV files"
            assert total_files > 0: "No pLDDT TSV files could be read"

            snapshot(
                plddt_files.size(),
                protein_scores.keySet().sort(),
                workflow.trace.succeeded().size()
            ).match()
        }
    }

    test("PAE matrix structure and validity") {
        options "-profile test_alphafold_fixed_seed"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            // Check for PAE TSV files (extract_metrics.py output for multi-chain systems)
            def pae_files = file("${params.outdir}/**/alphafold2/*/*/*pae*.tsv", relative: true)
            
            if (pae_files.size() > 0) {
                // Validate PAE TSV files are readable
                pae_files.each { pae_file ->
                    def content = pae_file.text
                    assert !content.isEmpty(): "Empty PAE TSV file: ${pae_file.name}"
                    // CSV parsing with proper tsv reader happens in Python
                }
            }

            snapshot(
                pae_files.size(),
                workflow.trace.succeeded().size()
            ).match()
        }
    }

    test("Output directory structure validation") {
        options "-profile test_alphafold_fixed_seed"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // Validate complete output directory structure
            def output_dir = file(params.outdir)
            
            // Should have alphafold2 results
            assert file("${params.outdir}/alphafold2").exists(): "No alphafold2 directory"
            
            // Should have split_msa_prediction subdirectory
            assert file("${params.outdir}/alphafold2/split_msa_prediction").exists(): "No split_msa_prediction directory"
            
            // Should have protein-specific directories
            def protein_dirs = file("${params.outdir}/alphafold2/split_msa_prediction").listFiles()
            assert protein_dirs.size() > 0: "No protein directories found"
            
            // PRIMARY: Each protein directory should have TSV outputs (extract_metrics.py product)
            protein_dirs.each { protein_dir ->
                if (protein_dir.isDirectory()) {
                    def plddt_tsvs = file("${protein_dir}/*plddt.tsv")
                    
                    // Must have pLDDT TSV output
                    assert plddt_tsvs.size() > 0: "No pLDDT TSV in ${protein_dir.name}"
                    
                    // Should also have PDB structures as input to extract_metrics
                    def pdb_files = file("${protein_dir}/*.pdb") + file("${protein_dir}/*.cif")
                    assert pdb_files.size() > 0: "No structures in ${protein_dir.name}"
                }
            }

            snapshot(
                protein_dirs.collect { it.name }.sort(),
                workflow.trace.succeeded().size()
            ).match()
        }
    }

    test("Deterministic output with fixed seed") {
        options "-profile test_alphafold_fixed_seed"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // When using fixed seed (42), outputs should be deterministic
            // PRIMARY: TSV outputs from extract_metrics.py should be consistent
            def plddt_files = file("${params.outdir}/**/alphafold2/*/*/*.plddt.tsv", relative: true)
            def pae_files = file("${params.outdir}/**/alphafold2/*/*/*.pae.tsv", relative: true)

            assert plddt_files.size() > 0: "No pLDDT TSV generated with fixed seed"

            // Validate TSV files are well-formed
            plddt_files.each { plddt_file ->
                def content = plddt_file.text
                assert !content.isEmpty(): "Empty pLDDT TSV: ${plddt_file.name}"
                // Content validation via Python csv parsing (not here)
            }

            // SECONDARY: Verify underlying PDB structures exist
            def pdb_files = file("${params.outdir}/**/alphafold2/*/*/*.pdb", relative: true)
            assert pdb_files.size() > 0: "No PDB structures generated with fixed seed"

            snapshot(
                plddt_files.collect { it.name }.sort(),
                pdb_files.size(),
                workflow.trace.succeeded().size()
            ).match()
        }
    }
}
