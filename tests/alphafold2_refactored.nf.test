/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    AlphaFold2 Reproducibility Test (using base helpers)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Refactored to use base validation helpers + advanced reproducibility checks.

    Pattern for modes with variants and reproducibility requirements:
    - Use base helpers for core output validation
    - Add mode-specific assertions for variant dir structure
    - Snapshot metrics counts (not values, since seed-dependent)
*/

nextflow_pipeline {

    name "Reproducibility validation: AlphaFold2 with fixed seed"
    script "../main.nf"
    tag "pipeline"
    tag "reproducibility"
    tag "alphafold2"

    test("alphafold2 split_msa_prediction: fixed seed reproducibility") {
        options "-profile test_alphafold2_split_fixed_seed"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // CORE VALIDATIONS
            assert validateModeMetrics(params.outdir, 'alphafold2'): \
                "AlphaFold2 metrics validation failed"

            def structure_count = validateModeStructures(params.outdir, '.pdb')
            assert structure_count > 0: "No PDB structures found"

            // ALPHAFOLD2-SPECIFIC: Validate variant directory structure
            def mode_structure = getModeOutputStructure(
                params.outdir,
                'alphafold2',
                'split_msa_prediction'
            )
            assert mode_structure.exists: "alphafold2/split_msa_prediction directory not found"

            // PAE matrices (optional, present for multimers)
            def pae_result = validatePAEOutput(params.outdir)

            // Get metrics summary
            def metrics_output = getMetricsOutput(params.outdir)

            // SNAPSHOT: With fixed seed, all outputs should be identical
            // So we snapshot both counts and file names
            snapshot(
                workflow.trace.succeeded().size(),
                mode_structure.protein_count,
                metrics_output.plddt_count,
                metrics_output.msa_count,
                structure_count,
                pae_result.count,
                metrics_output.plddt_names,  // With fixed seed: should be identical each run
                metrics_output.msa_names
            ).match()
        }
    }

    test("alphafold2 split_msa_prediction: random seed structure (fuzzy check)") {
        options "-profile test_alphafold2_split_random_seed_fuzzy"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // CORE VALIDATIONS: Outputs must exist and be well-formed
            // But values will differ due to random seed
            assert validateModeMetrics(params.outdir, 'alphafold2'): \
                "AlphaFold2 metrics validation failed with random seed"

            def structure_count = validateModeStructures(params.outdir, '.pdb')
            assert structure_count > 0: "No PDB structures generated"

            // MODE STRUCTURE (stable counts, not values)
            def mode_structure = getModeOutputStructure(
                params.outdir,
                'alphafold2',
                'split_msa_prediction'
            )

            def metrics_output = getMetricsOutput(params.outdir)

            // SNAPSHOT: With random seed, snapshot COUNTS and STRUCTURE only
            // NOT file content or values (those will vary)
            // This allows reproducible tests despite stochasticity
            snapshot(
                workflow.trace.succeeded().size(),
                mode_structure.protein_count,
                metrics_output.plddt_count,
                metrics_output.msa_count,
                structure_count,
                metrics_output.plddt_names.sort(),  // File names same, content differs
                metrics_output.msa_names.sort()
            ).match()
        }
    }

    test("alphafold2: PAE matrix validity (multimer systems)") {
        options "-profile test_alphafold2_split_fixed_seed"

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assert workflow.success

            // PAE is optional (only for multimers)
            def pae_result = validatePAEOutput(params.outdir)

            if (pae_result.exists) {
                // If PAE files exist, their counts should be reproducible
                snapshot(
                    pae_result.count
                ).match()
            }
            // If no PAE (monomer-only run), that's also valid
        }
    }
}
